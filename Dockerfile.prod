FROM node:22-slim
WORKDIR /app

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install pnpm
RUN npm install -g pnpm

# Force install ALL dependencies including dev (vite is needed at runtime for SSR)
RUN NODE_ENV=development pnpm install --dev

# Copy built files
COPY dist ./dist
COPY drizzle ./drizzle

EXPOSE 3000
ENV NODE_ENV=production
ENV PORT=3000
CMD ["node", "--max-old-space-size=512", "dist/index.js"]
